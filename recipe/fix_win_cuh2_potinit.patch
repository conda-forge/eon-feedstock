     end subroutine EAMRhoH
 
-      SUBROUTINE potinit()
+      SUBROUTINE cuh2_potinit()
 
         IMPLICIT NONE
         REAL*8 phitemp,dphidr_r,rhotemp,drhodr_r,potpar(18,3)
@@ -615,4 +615,4 @@
         rhocutH = rhotemp
         drhoHdr_r = drhodr_r
 
