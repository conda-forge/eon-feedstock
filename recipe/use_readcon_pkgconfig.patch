+    method: 'pkg-config',
+    required: false,
 )
-readcon_dep = readcon_proj.get_variable('readcon_dep')
+if not readcon_dep.found()
+    readcon_proj = subproject(
+        'readcon-core',
+        default_options: {
+            'with_tests': false,
+            'with_examples': false,
